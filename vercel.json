{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/commerce.framer.media/indexa5f6.html" },
    { "source": "/shop", "destination": "/commerce.framer.media/shop.html" },
    { "source": "/shop/:path*", "destination": "/commerce.framer.media/shop/:path*" },
    { "source": "/collections", "destination": "/commerce.framer.media/collections.html" },
    { "source": "/collections/:path*", "destination": "/commerce.framer.media/collections/:path*" },
    { "source": "/blog", "destination": "/commerce.framer.media/blog.html" },
    { "source": "/support", "destination": "/commerce.framer.media/support.html" },
    { "source": "/privacy-policy", "destination": "/commerce.framer.media/privacy-policy.html" },
    { "source": "/terms-and-conditions", "destination": "/commerce.framer.media/terms-and-conditions.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
